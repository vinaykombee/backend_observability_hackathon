{
  "title": "HTTP API Dashboard",
  "timezone": "browser",
  "schemaVersion": 36,
  "panels": [
    {
      "type": "timeseries",
      "title": "API Requests Per Second",
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "rate(http_requests_total[1m])",
          "legendFormat": "{{method}} {{path}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "API Error Rate",
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "targets": [
        {
          "expr": "rate(http_requests_total{status=\"500\"}[1m])"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "P95 Request Latency",
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[1m]))"
        }
      ]
    }
  ]
}